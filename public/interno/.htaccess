# La protezione primaria è ora JS (SHA-256 + sessionStorage) nell'HTML.
# Per aggiungere un secondo livello server-side, decommentare e configurare:
#
# AuthType Basic
# AuthName "GestHall Suite — Sezione Interna"
# AuthUserFile /home/USERNAME/.htpasswd_interno
# Require valid-user
#
# Creare il file con: htpasswd -c /home/USERNAME/.htpasswd_interno nomeutente
# USERNAME = nome utente SiteGround (Site Tools → SSH Keys Manager)

# Nessun indicizzazione da bot
Header set X-Robots-Tag "noindex, nofollow"
